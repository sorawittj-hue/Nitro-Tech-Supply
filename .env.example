VITE_API_BASE_URL=
VITE_MIMO_API_BASE_URL=https://api.xiaomimimo.com/v1
VITE_MIMO_API_KEY=
VITE_NITRO_PROXY_URL=http://localhost:8787
VITE_HERMES_API_URL=http://YOUR_AWS_IP:8642
VITE_HERMES_API_KEY=
VITE_HERMES_SESSION_KEY=nitro-tech-jay
VITE_WS_URL=ws://YOUR_AWS_IP:8642/ws
VITE_WS_TOKEN=

# Nitro proxy / backend runtime values. Keep these server-side only.
NITRO_PROXY_PORT=8787
DATA_API_URL=http://127.0.0.1:3030
NITRO_DATA_WRITE_TOKEN=
NITRO_REQUIRE_DATA_WRITE_TOKEN=true
NITRO_BACKUP_SOURCE=db.json
NITRO_BACKUP_DIR=backups/nitro-data
NITRO_BACKUP_RETENTION_DAYS=30

# Security note: if Hermes is exposed through a CORS wildcard reverse proxy,
# keep it for development only. Production should restrict origins and keep
# API_SERVER_KEY outside browser-delivered bundles whenever possible.
# For real business use, set NITRO_DATA_WRITE_TOKEN and switch
# NITRO_REQUIRE_DATA_WRITE_TOKEN=true before allowing public writes.
# For quick local-only experiments, you may temporarily set it false.
